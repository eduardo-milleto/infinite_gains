SCALE_IN_ENABLED=true
SCALE_IN_WINDOW_SECS=60
SCALE_IN_TRIGGER_DROP_CENTS=20
SCALE_IN_SIZE_MULTIPLIER=1.0

# Monitoring
METRICS_PORT=8080
