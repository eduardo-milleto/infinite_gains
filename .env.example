# Strategy params
STRATEGY_RSI_PERIOD=14
STRATEGY_RSI_OVERSOLD=30
STRATEGY_RSI_OVERBOUGHT=70
STRATEGY_STOCH_K_PERIOD=14
STRATEGY_STOCH_D_PERIOD=3
STRATEGY_STOCH_K_SMOOTH=3
STRATEGY_STOCH_OVERSOLD=20
STRATEGY_STOCH_OVERBOUGHT=80

# Market params
