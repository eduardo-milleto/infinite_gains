# PostgreSQL
POSTGRES_HOST=postgres
POSTGRES_PORT=5432
POSTGRES_DB=infinite_gains
POSTGRES_USER=infinite_gains
POSTGRES_PASSWORD=change-me
DATABASE_URL=postgresql+asyncpg://infinite_gains:change-me@postgres:5432/infinite_gains

# Polymarket CLOB (L1 + L2 - dedicated wallet only)
POLY_PRIVATE_KEY=<PRIVATE_KEY_HEX>
POLY_FUNDER_ADDRESS=0x0000000000000000000000000000000000000000
POLY_CHAIN_ID=137
POLY_CLOB_HOST=https://clob.polymarket.com
POLY_WS_HOST=wss://ws-subscriptions-clob.polymarket.com/ws/
POLY_API_KEY=
POLY_API_SECRET=
POLY_API_PASSPHRASE=

# TAAPI.IO
TAAPI_SECRET=
TAAPI_EXCHANGE=binance
TAAPI_SYMBOL=BTC/USDT
TAAPI_INTERVAL=1h
TAAPI_BACKTRACK=1

# Telegram
TELEGRAM_BOT_TOKEN=
TELEGRAM_ALLOWED_CHAT_IDS=123456789
TELEGRAM_ADMIN_USER_ID=123456789

# Trading mode
TRADING_MODE=PAPER

# Risk params
RISK_MAX_TRADE_USDC=10.00
RISK_MAX_DAILY_LOSS_USDC=15.00
RISK_MAX_TRADES_PER_DAY=6
RISK_MAX_OPEN_POSITIONS=1
RISK_COOLDOWN_SECONDS=300

# Strategy params
STRATEGY_RSI_PERIOD=14
STRATEGY_RSI_OVERSOLD=30
STRATEGY_RSI_OVERBOUGHT=70
STRATEGY_STOCH_K_PERIOD=14
STRATEGY_STOCH_D_PERIOD=3
STRATEGY_STOCH_K_SMOOTH=3
STRATEGY_STOCH_OVERSOLD=20
STRATEGY_STOCH_OVERBOUGHT=80

# Market params
MARKET_MAX_SPREAD=0.03
MARKET_NO_TRADE_BEFORE_CLOSE_SECS=120
MARKET_MAX_TRADES_PER_CANDLE=1

# Scheduler
SCHEDULER_POLL_INTERVAL_SECS=60

# Monitoring
METRICS_PORT=8080
GRAFANA_ADMIN_USER=admin
GRAFANA_ADMIN_PASSWORD=admin
